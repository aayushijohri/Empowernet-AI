# EmpowerNet AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file.

# ─── ML Configuration ────────────────────────────────────────────────────────
LOAD_MODELS=false          # Set to true to enable local heavy models (GPU recommended)
GEMINI_API_KEY=            # Required for cloud vision inference when LOAD_MODELS=false

# ─── Evidence Ledger (Blockchain) ────────────────────────────────────────────
# Leave blank to use local simulation mode (default — no credentials required).
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
PRIVATE_KEY=               # Your Polygon wallet private key (0x...)
CONTRACT_ADDRESS=          # Deployed EvidenceRegistry contract address (0x...)

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8001
